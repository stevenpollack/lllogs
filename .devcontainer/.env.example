# Copy this file to .devcontainer/.env (gitignored) and fill in BOTH secrets
# before opening the container. The devcontainer loads this file via `--env-file`,
# so the values are injected at run time and never baked into the image or git.
# post-create.sh fails fast if either is empty.

# Auth for the `claude` CLI.
ANTHROPIC_API_KEY=

# Auth for the `gh` CLI so the agent can open PRs. Use a FINE-GRAINED PAT scoped
# to only the repo(s) the sandbox should touch, with Contents: read/write and
# Pull requests: read/write, plus a short expiry:
#   https://github.com/settings/personal-access-tokens
# A broad classic PAT in a bypass-permissions sandbox has a large blast radius —
# keep it minimal.
GH_TOKEN=
