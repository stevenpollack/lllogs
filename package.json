{
  "name": "clogdy",
  "version": "0.0.0",
  "private": true,
  "description": "Investigate and monitor Claude Code tool usage — SQLite ingest, DuckDB analytics, React web UI",
  "workspaces": ["packages/*"],
  "scripts": {
    "check": "tsc --noEmit && bun run --filter '@clogdy/*' check",
    "test": "bun test",
    "lint": "oxlint packages",
    "lint:types": "oxlint --type-aware packages",
    "format": "oxfmt packages bun-test-setup.ts",
    "format:check": "oxfmt --check packages bun-test-setup.ts",
    "start": "bun run packages/server/src/start.ts",
    "v2": "bun run packages/server/src/start.ts",
    "v2:ingest": "bun run packages/ingest/src/cli.ts",
    "v2:serve": "bun run packages/server/src/serve.ts",
    "v2:analytics": "bun run packages/analytics/src/query.ts",
    "v2:web:build": "bun run packages/web/build.ts",
    "v2:web:watch": "bun run packages/web/build.ts --watch",
    "v2:dev": "bun run packages/server/src/start.ts --dev",
    "v2:tui": "bun run packages/tui/src/main.tsx",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/bun": "^1.3.14",
    "lefthook": "^2.1.9",
    "oxfmt": "0.56.0",
    "oxlint": "1.71.0",
    "oxlint-tsgolint": "0.23.0",
    "pino-pretty": "^13.1.3",
    "typescript": "^5.5.0"
  }
}
